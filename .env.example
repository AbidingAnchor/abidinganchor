# API.Bible (scripture.api.bible) — free key: https://scripture.api.bible
# Used for scripture text in the reader when set. Copy to `.env` and restart Vite.
VITE_API_BIBLE_KEY=

# YouTube Data API v3 — https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Restrict key by HTTP referrer (web) in Google Cloud. Used for Bible Project channel listing.
VITE_YOUTUBE_API_KEY=

# Discord webhooks — copy to `.env`; do not commit secrets.
# Settings → Send Feedback
VITE_DISCORD_FEEDBACK_WEBHOOK_URL=
# Prayer Wall (if used)
VITE_DISCORD_WEBHOOK_URL=

# AI Companion API — deployed URL for local development
# Copy to `.env.local` with your deployed Vercel/Netlify URL
# Example: VITE_AI_API_URL=https://your-app.vercel.app/api/ai-companion
VITE_AI_API_URL=

# Optional: pin a Bible id from the API.Bible catalog (otherwise resolved by app language).
# VITE_API_BIBLE_ID=
# VITE_API_BIBLE_ID_ES=
# VITE_API_BIBLE_ID_PT=
# VITE_API_BIBLE_ID_FR=
# VITE_API_BIBLE_ID_DE=
# VITE_API_BIBLE_ID_HI=
