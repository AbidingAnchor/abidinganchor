  "encounter": {
    "love": {
      "reflection": "从神开始的爱在你证明任何东西之前就到达你。",
      "prompt": "今天你在哪里需要重新接受祂的爱?"
    },
    "faith": {
      "reflection": "信心是一个让你稳定的恩赐 — 不是你必须完美通过的测试。",
      "prompt": "今天耶稣要求你采取什么信靠的步骤?"
    },
    "hope": {
      "reflection": "当环境仍然变化时，盼望在真理中锚定你。",
      "prompt": "你现在想将什么情况放在祂的手中?"
    },
    "strength": {
      "reflection": "你不是注定要靠自己的力量承担一切。",
      "prompt": "你在哪里更需要祂的力量而不是你的努力?"
    },
    "peace": {
      "reflection": "平安不是噪音的缺席 — 它是祂在噪音中的同在。",
      "prompt": "今天在一个焦虑的时刻接受祂的平安会是什么样子?"
    },
    "grace": {
      "reflection": "恩典在你所在的地方遇见你，并温柔地呼唤你前进。",
      "prompt": "今天你在哪里需要扩展 — 或接受 — 恩典?"
    },
    "prayer": {
      "reflection": "当你诚实地说话时，神弯下腰 — 而不是当你润色每个词时。",
      "prompt": "此时此刻你想与神谈论什么?"
    },
    "forgiveness": {
      "reflection": "宽恕来自一个首先被大大宽恕的心。",
      "prompt": "是否有关系需要祂的帮助来宽恕或寻求和平?"
    },
    "trust": {
      "reflection": "信靠是当你无法看到完整的道路时选择依靠祂。",
      "prompt": "今天你想在祂面前带来什么不确定性?"
    },
    "courage": {
      "reflection": "勇气不是恐惧的缺席 — 它是与祂一起走过恐惧。",
      "prompt": "你在哪里需要勇气来顺从或在爱中说真理?"
